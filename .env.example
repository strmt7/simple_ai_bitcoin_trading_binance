# Environment overrides read by simple-ai-trading at runtime. Copy to `.env`
# and fill in locally — never commit a populated `.env`.

# Disable ANSI color in CLI + shell output (set to any non-empty string).
NO_COLOR=

# Force ANSI color even when stdout is not a terminal.
FORCE_COLOR=

# Override the Binance base URL for both spot and futures (e.g. for a proxy).
BINANCE_BASE_URL=

# Override only the spot base URL.
BINANCE_SPOT_BASE_URL=

# Override only the USD-M futures base URL.
BINANCE_FUTURES_BASE_URL=

# GitHub Personal Access Token used by tools/push_with_pat.py — do NOT commit.
# The token is read from the environment and fed to git over a short-lived
# socket; it never touches the remote URL, credential helper, or log files.
GITHUB_TOKEN=
